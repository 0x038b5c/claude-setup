# AUTO-GENERATED by claude-setup — do not edit manually.
# Mode A: config-driven (fleet mode)
# Invocation:
#   PYTHONPATH=/mnt/skills/user/loader python -m src.main \
#     --uuid <UUID> --config <user/config-repo>
import shutil
import subprocess
import sys
import tomllib
from pathlib import Path

import click

ROOT_DIR = Path(__file__).resolve().parent.parent


def run(cmd, **kwargs):
    result = subprocess.run(cmd, shell=True, text=True, capture_output=True, **kwargs)
    if result.returncode != 0:
        print(f"ERROR running: {cmd}")
        print(result.stderr)
    return result, result.returncode == 0


@click.command()
@click.option("--uuid", required=True, help="Account UUID")
@click.option("--config", required=True, help='Config repo in "user/repo" form')
def main(uuid: str, config: str):
    # 1. Install age key — the only thing hardcoded into this zip
    shutil.copy(ROOT_DIR / "keys" / "age.key", "/opt/age.key")
    print("Age key installed at /opt/age.key")

    # 2. Write identity so payload knows who it is
    Path("/opt/account-uuid").write_text(uuid)
    print(f"Identity: uuid={uuid}")

    # 3. Clone config so payload can resolve everything else from it
    config_url = f"https://github.com/{config}"
    shutil.rmtree("/opt/claude-config", ignore_errors=True)
    _, ok = run(f"git clone {config_url} /opt/claude-config --depth 1")
    if not ok:
        print("ERROR: failed to clone claude-config", file=sys.stderr)
        sys.exit(1)
    print(f"Config: {config_url}")

    # 4. Resolve payload repo from config
    with open("/opt/claude-config/config.toml", "rb") as f:
        cfg = tomllib.load(f)
    g = cfg.get("global", {})
    acct = cfg.get("account", {}).get(uuid, {})
    payload_repo = acct.get("payload_repo") or g.get("payload_repo")
    if not payload_repo:
        print("ERROR: global.payload_repo not set in config.toml", file=sys.stderr)
        sys.exit(1)
    payload_url = f"https://github.com/{payload_repo}"

    # 5. Clone and run payload — no arguments needed, payload reads /opt/account-uuid
    shutil.rmtree("/opt/payload", ignore_errors=True)
    run(f"git clone {payload_url} /opt/payload --depth 1")
    result, _ = run("PYTHONPATH=/opt/payload python -m src.main")
    print(result.stdout)
    if result.stderr:
        print("STDERR:", result.stderr)


if __name__ == "__main__":
    main()
