# Mode B: simple/single-account mode
# Invocation: PYTHONPATH=/mnt/skills/user/loader python -m src.main --username <USERNAME> --payload-repo <URL>
import shutil
import subprocess
from pathlib import Path

ROOT_DIR = Path(__file__).resolve().parent.parent


def run(cmd, **kwargs):
    result = subprocess.run(cmd, shell=True, text=True, capture_output=True, **kwargs)
    if result.returncode != 0:
        print(f"ERROR running: {cmd}")
        print(result.stderr)
    return result, result.returncode == 0


def main(github_username: str, payload_repo: str):
    # 1. Install age key — the only thing hardcoded into this zip
    shutil.copy(ROOT_DIR / "keys" / "age.key", "/opt/age.key")
    print("Age key installed at /opt/age.key")

    # 2. Write identity so payload knows who it is (and which mode)
    Path("/opt/github-username").write_text(github_username)
    print(f"Identity: username={github_username}")

    # 3. Clone and run payload — no arguments needed, payload reads /opt/github-username
    shutil.rmtree("/opt/payload", ignore_errors=True)
    _, ok = run(f"git clone {payload_repo} /opt/payload --depth 1")
    if not ok:
        raise RuntimeError(f"Failed to clone payload from {payload_repo}")
    result, _ = run("PYTHONPATH=/opt/payload python -m src.main")
    print(result.stdout)
    if result.stderr:
        print("STDERR:", result.stderr)


if __name__ == "__main__":
    import argparse
    p = argparse.ArgumentParser(description="Claude loader — simple/single-account mode")
    p.add_argument("--username", required=True, help="GitHub username")
    p.add_argument("--payload-repo", required=True, help="URL of claude-payload repo")
    args = p.parse_args()
    main(github_username=args.username, payload_repo=args.payload_repo)
