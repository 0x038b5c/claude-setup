import shutil
import subprocess
import sys
from pathlib import Path

import click

ROOT_DIR = Path(__file__).resolve().parent.parent


def run(cmd, **kwargs):
    result = subprocess.run(cmd, shell=True, text=True, capture_output=True, **kwargs)
    if result.returncode != 0:
        print(f"ERROR running: {cmd}")
        print(result.stderr)
    return result, result.returncode == 0


@click.command()
@click.option("--user", required=True, help="GitHub username")
def main(user: str):
    # 1. Install age key — the only thing hardcoded into this zip
    shutil.copy(ROOT_DIR / "keys" / "age.key", "/opt/age.key")
    print("Age key installed at /opt/age.key")

    # 2. Write identity so payload knows who it is (and which mode)
    Path("/opt/github-username").write_text(user)
    print(f"Identity: username={user}")

    # 3. Clone and run payload — no arguments needed, payload reads /opt/github-username
    payload_url = f"https://github.com/{user}/claude-payload"
    shutil.rmtree("/opt/payload", ignore_errors=True)
    _, ok = run(f"git clone {payload_url} /opt/payload --depth 1")
    if not ok:
        print(f"ERROR: failed to clone {payload_url}", file=sys.stderr)
        sys.exit(1)
    result, _ = run("PYTHONPATH=/opt/payload python -m src.main")
    print(result.stdout)
    if result.stderr:
        print("STDERR:", result.stderr)


if __name__ == "__main__":
    main()
